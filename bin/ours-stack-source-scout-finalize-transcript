#!/usr/bin/env bash
# Append preflight + validate lines to scout-transcript.jsonl after a scout run.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TRANSCRIPT="${1:-}"
BRIEF="${2:-}"

usage() {
  echo "Usage: ours-stack-source-scout-finalize-transcript <transcript.jsonl> <brief.md>" >&2
  exit 2
}

[ -n "$TRANSCRIPT" ] && [ -f "$TRANSCRIPT" ] || usage
[ -n "$BRIEF" ] && [ -f "$BRIEF" ] || usage

command -v jq >/dev/null 2>&1 || { echo "finalize-transcript: jq required" >&2; exit 1; }

PREFLIGHT="$REPO_ROOT/bin/ours-stack-source-scout-preflight"
TRANSCRIPT_CHECK="$REPO_ROOT/bin/ours-stack-source-scout-transcript-check"
VALIDATE="$REPO_ROOT/bin/ours-stack-source-scout-validate"

EVIDENCE="$REPO_ROOT/bin/ours-stack-source-scout-evidence-check"
RAW="${3:-}"

"$PREFLIGHT" "$BRIEF" >/dev/null
echo '{"tool":"preflight","status":"ok"}' >>"$TRANSCRIPT"

val_msg="$("$VALIDATE" "$BRIEF" 2>&1)"
jq -cn --arg m "$val_msg" '{tool:"validate",status:"ok",message:$m}' >>"$TRANSCRIPT"

if [ -n "$RAW" ] && [ -f "$RAW" ]; then
  "$EVIDENCE" "$RAW" "$TRANSCRIPT" >/dev/null
fi
"$TRANSCRIPT_CHECK" "$TRANSCRIPT" "$BRIEF" >/dev/null

echo "finalize-transcript: OK — $TRANSCRIPT"
exit 0
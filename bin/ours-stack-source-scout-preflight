#!/usr/bin/env bash
# Pre-write checks: skill invariants (timebox, gate, swap rules) + brief wedge present.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SKILL="$REPO_ROOT/source-scout/SKILL.md"
TIERS="$REPO_ROOT/source-scout/references/source-tiers.md"
BRIEF="${1:-}"

fail() { echo "source-scout-preflight: $*" >&2; exit 1; }

[ -f "$SKILL" ] || fail "missing $SKILL"
[ -f "$TIERS" ] || fail "missing $TIERS"

grep -q 'max \*\*2 minutes\*\*' "$SKILL" || fail "YouTube timebox 2 min not in SKILL.md"
grep -q 'max \*\*3\*\* `WebFetch`' "$SKILL" || fail "YouTube max 3 WebFetch not in SKILL.md"
grep -q 'Swap heuristics' "$SKILL" || fail "Swap heuristics missing"
grep -qE 'ours-stack-source-scout-(validate|finalize-transcript)' "$SKILL" || fail "validate/finalize gate not referenced in SKILL.md"
grep -qE 'ours-stack-source-scout-(transcript-check|finalize-transcript)' "$SKILL" || fail "transcript-check/finalize gate not referenced in SKILL.md"
grep -q 'scout-transcript.jsonl' "$SKILL" || fail "scout-transcript.jsonl audit trail not in SKILL.md"
grep -q 'scout-raw.jsonl' "$SKILL" || fail "scout-raw.jsonl live capture not in SKILL.md"
grep -q 'ours-stack-source-scout-log-tool' "$SKILL" || fail "log-tool not referenced in SKILL.md"
grep -q 'ours-stack-source-scout-run' "$SKILL" || fail "source-scout-run engine not referenced in SKILL.md"
grep -qE 'ours-stack-source-scout-(evidence-check|finalize-transcript)' "$SKILL" || fail "evidence-check/finalize not referenced in SKILL.md"
[ -x "$REPO_ROOT/bin/ours-stack-source-scout-log-tool" ] || fail "log-tool bin missing or not executable"
[ -x "$REPO_ROOT/bin/ours-stack-source-scout-run" ] || fail "source-scout-run bin missing or not executable"
[ -f "$REPO_ROOT/source-scout/scripts/scout-engine.py" ] || fail "scout-engine.py missing"
[ -x "$REPO_ROOT/bin/ours-stack-source-scout-evidence-check" ] || fail "evidence-check bin missing or not executable"
[ -x "$REPO_ROOT/bin/ours-stack-source-scout-sync-transcript-from-raw" ] || fail "sync-from-raw bin missing or not executable"
grep -q 'git rev-parse --show-toplevel' "$SKILL" || fail "repo-root validate path not in SKILL.md"
grep -q 'timebox 2 min' "$TIERS" || fail "timebox note missing in source-tiers.md"

if [ -n "$BRIEF" ]; then
  [ -f "$BRIEF" ] || fail "brief not found: $BRIEF"
  grep -q '## Narrow wedge' "$BRIEF" || fail "brief missing ## Narrow wedge"
  grep -q '## Success criteria' "$BRIEF" || fail "brief missing ## Success criteria"
fi

echo "source-scout-preflight: OK — skill invariants +${BRIEF:+ brief wedge}"
exit 0
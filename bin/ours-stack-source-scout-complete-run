#!/usr/bin/env bash
# Complete one scout run: ingest live provider log → sync → finalize gates.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
INGEST="$REPO_ROOT/bin/ours-stack-source-scout-ingest-provider-log"
SYNC="$REPO_ROOT/bin/ours-stack-source-scout-sync-transcript-from-raw"
FINALIZE="$REPO_ROOT/bin/ours-stack-source-scout-finalize-transcript"

PROVIDER_LOG="${1:-}"
RAW="${2:-}"
TRANSCRIPT="${3:-}"
BRIEF="${4:-}"
RUN="${5:-}"

usage() {
  echo "Usage: ours-stack-source-scout-complete-run <provider.log> <raw.jsonl> <transcript.jsonl> <brief.md> <run_id>" >&2
  exit 2
}

[ -n "$PROVIDER_LOG" ] && [ -f "$PROVIDER_LOG" ] || usage
[ -n "$RAW" ] || usage
[ -n "$TRANSCRIPT" ] || usage
[ -n "$BRIEF" ] && [ -f "$BRIEF" ] || usage
[ -n "$RUN" ] || usage

"$INGEST" "$PROVIDER_LOG" "$RAW" "$RUN"
"$SYNC" "$RAW" "$TRANSCRIPT"
"$FINALIZE" "$TRANSCRIPT" "$BRIEF" "$RAW"

echo "complete-run: OK — run $RUN gates passed for $BRIEF"
exit 0
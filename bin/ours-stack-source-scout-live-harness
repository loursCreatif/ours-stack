#!/usr/bin/env bash
# Live scout harness: run source-scout-run on a fresh provider cassette for a study brief.
# Agent workflow: WebSearch/WebFetch live → append JSON lines to provider.log → invoke this script.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
RUN="$REPO_ROOT/bin/ours-stack-source-scout-run"

BRIEF="${1:-}"
CASSETTE="${2:-}"

usage() {
  echo "Usage: ours-stack-source-scout-live-harness <brief.md> [provider.log]" >&2
  echo "  Default provider.log: studies/<slug>/provider.log next to brief" >&2
  exit 2
}

[ -n "$BRIEF" ] && [ -f "$BRIEF" ] || usage

slug="$(basename "$(dirname "$BRIEF")")"
CASSETTE="${CASSETTE:-$REPO_ROOT/studies/$slug/provider.log}"
[ -f "$CASSETTE" ] || { echo "live-harness: missing provider cassette: $CASSETTE" >&2; exit 1; }

lines="$(grep -c . "$CASSETTE" || true)"
ws="$(grep -c '"tool":"WebSearch"' "$CASSETTE" || true)"
wf="$(grep -c '"tool":"WebFetch"' "$CASSETTE" || true)"
[ "$lines" -ge 3 ] || { echo "live-harness: provider.log needs >=3 lines (got $lines)" >&2; exit 1; }
[ "$ws" -ge 3 ] || { echo "live-harness: need >=3 WebSearch lines (got $ws)" >&2; exit 1; }
[ "$wf" -ge 1 ] || { echo "live-harness: need >=1 WebFetch line (got $wf)" >&2; exit 1; }

MANIFEST="${CASSETTE%.log}.manifest.json"
RAW="$REPO_ROOT/studies/$slug/scout-raw.jsonl"
TRANSCRIPT="$REPO_ROOT/studies/$slug/scout-transcript.jsonl"

"$RUN" --brief "$BRIEF" --cassette "$CASSETTE" --run-id "live" \
  --out "$BRIEF" --raw "$RAW" --transcript "$TRANSCRIPT" --manifest "$MANIFEST"

echo "live-harness: OK — $CASSETTE → $BRIEF (manifest: $MANIFEST)"
exit 0
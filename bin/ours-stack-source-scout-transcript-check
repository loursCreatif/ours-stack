#!/usr/bin/env bash
# Verify scout-transcript.jsonl proves tool calls that sourced brief URLs.
set -euo pipefail

TRANSCRIPT="${1:-}"
BRIEF="${2:-}"

usage() {
  echo "Usage: ours-stack-source-scout-transcript-check <transcript.jsonl> <brief.md>" >&2
  exit 2
}

[ -n "$TRANSCRIPT" ] && [ -f "$TRANSCRIPT" ] || usage
[ -n "$BRIEF" ] && [ -f "$BRIEF" ] || usage

fail() { echo "transcript-check: $*" >&2; exit 1; }

command -v jq >/dev/null 2>&1 || fail "jq required"

# Reject empty or non-JSONL prose
[ -s "$TRANSCRIPT" ] || fail "transcript empty"
while IFS= read -r line; do
  [ -z "$line" ] && continue
  echo "$line" | jq -e . >/dev/null 2>&1 || fail "non-JSON line in transcript"
done <"$TRANSCRIPT"

ws_count="$(jq -s '[.[] | select(.tool=="WebSearch")] | length' "$TRANSCRIPT")"
wf_count="$(jq -s '[.[] | select(.tool=="WebFetch")] | length' "$TRANSCRIPT")"
val_ok="$(jq -s '[.[] | select(.tool=="validate" and .status=="ok")] | length' "$TRANSCRIPT")"

[ "$ws_count" -ge 3 ] || fail "need >=3 WebSearch lines (got $ws_count)"
[ "$wf_count" -ge 1 ] || fail "need >=1 WebFetch lines (got $wf_count)"
[ "$val_ok" -ge 1 ] || fail "need >=1 validate status=ok line"

# Tool lines must carry live-audit fields (ts + raw_seq link to scout-raw.jsonl)
tool_lines="$(jq -s '[.[] | select(.tool=="WebSearch" or .tool=="WebFetch")] | length' "$TRANSCRIPT")"
ts_ok="$(jq -s '[.[] | select(.tool=="WebSearch" or .tool=="WebFetch") | select(.ts != null and .ts != "")] | length' "$TRANSCRIPT")"
seq_ok="$(jq -s '[.[] | select(.tool=="WebSearch" or .tool=="WebFetch") | select(.raw_seq != null)] | length' "$TRANSCRIPT")"
[ "$ts_ok" -eq "$tool_lines" ] || fail "every WebSearch/WebFetch needs ts (got $ts_ok/$tool_lines)"
[ "$seq_ok" -eq "$tool_lines" ] || fail "every WebSearch/WebFetch needs raw_seq (got $seq_ok/$tool_lines)"

# Collect all URLs from transcript (search results + fetch urls)
transcript_urls="$(mktemp)"
jq -s -r '
  .[] |
  if .tool == "WebSearch" then (.results[]? // empty)
  elif .tool == "WebFetch" then .url // empty
  else empty end
' "$TRANSCRIPT" 2>/dev/null | sed 's/[[:space:]]*$//' | sort -u >"$transcript_urls"

# Extract https URLs from brief source lines
brief_urls="$(mktemp)"
grep -oE 'https://[^ )>]+' "$BRIEF" | sed 's/[[:space:]]*$//' | sort -u >"$brief_urls"

missing=0
while IFS= read -r url; do
  [ -z "$url" ] && continue
  # normalize: brief URL may be substring of transcript URL or exact match
  if ! grep -qF "$url" "$transcript_urls"; then
    echo "transcript-check: brief URL not in transcript: $url" >&2
    missing=$((missing + 1))
  fi
done <"$brief_urls"

rm -f "$transcript_urls" "$brief_urls"
[ "$missing" -eq 0 ] || fail "$missing brief URL(s) not found in transcript"

echo "transcript-check: OK — WebSearch=$ws_count WebFetch=$wf_count validate_ok=$val_ok"
exit 0
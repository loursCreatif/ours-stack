#!/usr/bin/env bash
# Ingest live WebSearch/WebFetch provider captures → scout-raw.jsonl via log-tool.
# Each line of PROVIDER_LOG is JSON: {tool,query|url,provider_status,results|status,snippet_chars?}
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LOG="$REPO_ROOT/bin/ours-stack-source-scout-log-tool"
PROVIDER_LOG="${1:-}"
RAW="${2:-}"
RUN="${3:-}"

usage() {
  echo "Usage: ours-stack-source-scout-ingest-provider-log <provider.log> <scout-raw.jsonl> <run_id>" >&2
  exit 2
}

[ -n "$PROVIDER_LOG" ] && [ -f "$PROVIDER_LOG" ] || usage
[ -n "$RAW" ] || usage
[ -n "$RUN" ] || usage
[ -x "$LOG" ] || { echo "ingest-provider: log-tool missing" >&2; exit 1; }

: >"$RAW"
n=0
while IFS= read -r line; do
  [ -z "$line" ] && continue
  echo "$line" | jq -e . >/dev/null 2>&1 || { echo "ingest-provider: bad JSON: $line" >&2; exit 1; }
  tool="$(echo "$line" | jq -r '.tool')"
  case "$tool" in
    WebSearch)
      query="$(echo "$line" | jq -r '.query')"
      ps="$(echo "$line" | jq -r '.provider_status // "ok"')"
      count="$(echo "$line" | jq -r '[.results[]?] | length')"
      if [ "$count" -gt 0 ]; then
        urls="$(echo "$line" | jq -r '[.results[]?] | join(",")')"
        "$LOG" --raw "$RAW" --run "$RUN" --tool WebSearch --query "$query" --urls "$urls" --provider-status "$ps"
      elif [ "$ps" = "error" ]; then
        "$LOG" --raw "$RAW" --run "$RUN" --tool WebSearch --query "$query" --urls "" --provider-status error
      else
        echo "ingest-provider: WebSearch missing results: $query" >&2
        exit 1
      fi
      ;;
    WebFetch)
      url="$(echo "$line" | jq -r '.url')"
      status="$(echo "$line" | jq -r '.status // "ok"')"
      sc="$(echo "$line" | jq -r '.snippet_chars // empty')"
      author="$(echo "$line" | jq -r '.author // empty')"
      args=(--raw "$RAW" --run "$RUN" --tool WebFetch --url "$url" --status "$status")
      [ -n "$sc" ] && args+=(--snippet-chars "$sc")
      [ -n "$author" ] && args+=(--author "$author")
      "$LOG" "${args[@]}"
      ;;
    *) echo "ingest-provider: skip tool $tool" >&2 ;;
  esac
  n=$((n + 1))
done <"$PROVIDER_LOG"

echo "ingest-provider: OK — $n provider lines → $RAW"
exit 0
#!/usr/bin/env bash
# Validate ## Source material in a study brief — contract + score gate.
# Exit 0 only when structure is valid and every source + set score >= MIN (default 9).
set -euo pipefail

MIN_SCORE="${SOURCE_SCOUT_MIN_SCORE:-9}"
BRIEF="${1:-}"

usage() {
  echo "Usage: ours-stack-source-scout-validate <brief.md>" >&2
  echo "  SOURCE_SCOUT_MIN_SCORE=N  (default 9)" >&2
  exit 2
}

[ -n "$BRIEF" ] && [ -f "$BRIEF" ] || usage

fail() { echo "source-scout-validate: $*" >&2; exit 1; }

# Extract ## Source material section (until next ## at column 0)
section="$(
  awk '
    /^## Source material/ { in_s=1; print; next }
    in_s && /^## / { exit }
    in_s { print }
  ' "$BRIEF"
)"

[ -n "$section" ] || fail "missing ## Source material section"

# Header must match skill template exactly (date flexible)
header="$(echo "$section" | grep -E '^Scouted [0-9]{4}-[0-9]{2}-[0-9]{2} via `/source-scout` :$' | head -1 || true)"
if [ -z "$header" ]; then
  got="$(echo "$section" | grep '^Scouted' | head -1 || echo '(none)')"
  fail "header must be: Scouted YYYY-MM-DD via \`/source-scout\` : (got: $got)"
fi

echo "$section" | grep -q "### Read first (anchor)" || fail "missing ### Read first (anchor)"
echo "$section" | grep -q "### Core" || fail "missing ### Core"
echo "$section" | grep -q "### Skipped (wedge boundary)" || fail "missing ### Skipped (wedge boundary)"

source_count="$(echo "$section" | grep -cE '^- \[[ x]\] \*\*' || true)"
[ "$source_count" -eq 3 ] || fail "expected exactly 3 sources, found $source_count"

# Validate each source entry (lines after - [ ] ** until next source or ###)
idx=0
while IFS= read -r title_line; do
  [ -z "$title_line" ] && continue
  idx=$((idx + 1))
  # Grab following indented bullets until next top-level list item or ###
  block="$title_line"
  rest="$(echo "$section" | awk -v start="$title_line" '
    $0 == start { found=1; next }
    found && (/^- \[[ x]\] \*\*/ || /^### /) { exit }
    found { print }
  ')"
  block="${block}"$'\n'"${rest}"
  echo "$block" | grep -qE '^[[:space:]]{2}- Format:' || fail "source $idx missing Format:"
  echo "$block" | grep -qE '^[[:space:]]{2}- Tier:' || fail "source $idx missing Tier:"
  echo "$block" | grep -qE '^[[:space:]]{2}- Why:' || fail "source $idx missing Why:"
  echo "$block" | grep -qE '^[[:space:]]{2}- Targets:' || fail "source $idx missing Targets:"
  score_line="$(echo "$block" | grep -E '^[[:space:]]{2}- Score:' | head -1 || true)"
  [ -n "$score_line" ] || fail "source $idx missing Score: N/10"
  score="$(echo "$score_line" | sed -E 's/^[[:space:]]*- Score:[[:space:]]*([0-9]+)\/10.*/\1/')"
  [ -n "$score" ] || fail "source $idx Score: must be N/10 (got: $score_line)"
  if [ "$score" -lt "$MIN_SCORE" ] 2>/dev/null; then
    fail "source $idx score $score/10 below minimum $MIN_SCORE/10"
  fi
done < <(echo "$section" | grep -E '^- \[[ x]\] \*\*')

[ "$idx" -eq 3 ] || fail "parsed $idx source blocks, expected 3"

echo "$section" | grep -q "### Scout scores" || fail "missing ### Scout scores subsection"
set_line="$(echo "$section" | grep -E '^- Set:' | head -1 || true)"
[ -n "$set_line" ] || fail "missing - Set: N/10 line under ### Scout scores"
set_score="$(echo "$set_line" | sed -E 's/^- Set:[[:space:]]*([0-9]+)\/10.*/\1/')"
[ -n "$set_score" ] || fail "Set score must be N/10 (got: $set_line)"
if [ "$set_score" -lt "$MIN_SCORE" ] 2>/dev/null; then
  fail "set score $set_score/10 below minimum $MIN_SCORE/10"
fi

echo "source-scout-validate: OK — 3 sources, scores >= $MIN_SCORE/10, set $set_score/10"
exit 0
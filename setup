#!/usr/bin/env bash
# ours-stack setup — link skills + create state dir
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
STATE_DIR="${OURS_STACK_HOME:-$HOME/.ours-stack}"

mkdir -p "$STATE_DIR"
touch "$STATE_DIR/learnings.jsonl"

mkdir -p "$HOME/.claude/skills"
ln -sfn "$REPO_ROOT" "$HOME/.claude/skills/ours-stack"

echo "ours-stack ready"
echo "  skills -> ~/.claude/skills/ours-stack"
echo "  state  -> $STATE_DIR/learnings.jsonl"
echo ""
echo "Use: /bear-hours  /dense-read  /checkpoint-learnings"
echo "Grok Build sees these via Claude compat (no extra install)."